{
  "name": "astraquant-vite",
  "private": true,
  "version": "0.1.2",
  "description": "AstraQuant market intelligence desktop terminal.",
  "author": "SuperWindCloud",
  "homepage": "https://github.com/Super1WindCloud",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tv:bridge": "node scripts/tradingview-chart.cjs",
    "td": "tauri dev ",
    "tb": "tauri build",
    "taze": "npx taze latest -w",
    "shadcn": "npx shadcn@latest add -a -y -o",
    "cargo-update": "cd src-tauri && cargo upgrade",
    "clean": "npx rimraf node_modules && pnpm cargo-clean",
    "cargo-clean": "cd src-tauri && cargo clean",
    "lint": "biome check . && cd src-tauri && cargo check",
    "format": "biome format --write . && cd src-tauri && cargo fmt",
    "icon": "tauri icon  app-icon.png",
    "bump": "pnpm taze && pnpm cargo-update && pnpm shadcn",
    "check": "biome check  && cd src-tauri && cargo check",
    "fix": "biome check   --fix && cd src-tauri && cargo fmt",
    "test": "vitest",
    "migrate": "biome migrate --write"
  },
